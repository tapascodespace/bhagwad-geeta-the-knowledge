# Frontend (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
# Dashboard → Project Settings → API → Publishable key (sb_publishable_... or legacy anon JWT)
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server / scripts / edge functions (never expose in Vite)
# Dashboard → Secret key (sb_secret_... or legacy service_role JWT)
SUPABASE_SECRET_KEY=your-secret-key

# Optional legacy alias
# SUPABASE_SERVICE_ROLE_KEY=
